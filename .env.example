APP_NAME=IT Asset Hub
SECRET_KEY=change-me-in-production
APP_BASE_URL=http://127.0.0.1:8010
APP_HOST=127.0.0.1
APP_PORT=8010
DATA_DIR=data
DATABASE_URL=sqlite:///data/it_asset_hub.db
SESSION_COOKIE_NAME=session
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_SECURE=false
IS_PRODUCTION=false
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123
AUTO_CREATE_DEFAULT_ADMIN=true
AUTO_BACKFILL_ASSET_EVENTS=true

# Zalo Bot Notification
# Endpoint API bot Zalo (do Zalo cung cấp khi tạo bot)
ZALO_BOT_URL=https://openapi.zalo.me/v2.0/oa/message
# Mã thông báo (Access token hoặc API key của Bot)
ZALO_BOT_TOKEN=your_zalo_bot_token_here
# ID của người nhận thông báo (User ID, Phone, hoặc Group ID tuỳ API)
ZALO_NOTIFICATION_TARGET=your_target_id_here
# Example Postgres:
# DATABASE_URL=postgresql+psycopg://itassethub_user:strong_password@127.0.0.1:5432/it_asset_hub
# Example external env file on Windows service:
# IT_ASSET_HUB_ENV_FILE=D:\Apps\ITAssetHub\shared\env\it_asset_hub.env
